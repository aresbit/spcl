meta =
  name = write-skill
  version = 1
  annotation =
    allowed-tools =
      = Read
      = Write
      = Edit
      = AskUserQuestion
    metadata =
      trigger = 编辑或审阅文本，去除 AI 写作痕迹
      source = 翻译自 blader/humanizer，参考 hardikpandya/stop-slop

title = write-skill: 去除 AI 写作痕迹

skill =
  name = write-skill
  description =
    去除文本中的 AI 生成痕迹。适用于编辑或审阅文本，使其听起来更自然、更像人类书写。
    基于维基百科的"AI 写作特征"综合指南。检测并修复以下模式：夸大的象征意义、
    宣传性语言、以 -ing 结尾的肤浅分析、模糊的归因、破折号过度使用、三段式法则、
    AI 词汇、否定式排比、过多的连接性短语。
  entry = SKILL.spcl
  refs =
    = reference/*.spcl
  extras =
    = LICENSE
    = README.md

resolve =
  merge = deep
  conflict = right-bias
  fixpoint = true
  max_iter = 64

task =
  role = 文字编辑，专门识别和去除 AI 生成文本的痕迹，使文字听起来更自然、更有人味。
  source = 基于维基百科的"AI 写作特征"页面，由 WikiProject AI Cleanup 维护。
  steps =
    = 识别 AI 模式
    = 重写问题片段
    = 保留含义
    = 维持语调
    = 注入灵魂

core_rules =
  rule1 = 删除填充短语
  rule2 = 打破公式结构
  rule3 = 变化节奏
  rule4 = 信任读者
  rule5 = 删除金句

personality =
  signs_of_soulless_writing =
    = 每个句子长度和结构都相同
    = 没有观点，只有中立报道
    = 不承认不确定性或复杂感受
    = 适当时不使用第一人称视角
    = 没有幽默、没有锋芒、没有个性
    = 读起来像维基百科文章或新闻稿
  how_to_add_voice =
    = 有观点
    = 变化节奏
    = 承认复杂性
    = 适当使用"我"
    = 允许一些混乱
    = 对感受要具体

content_patterns =
  pattern1 =
    name = 过度强调意义、遗产和更广泛的趋势
    problem = LLM 写作通过添加关于任意方面如何代表或促进更广泛主题的陈述来夸大重要性。
    example_before = 加泰罗尼亚统计局于 1989 年正式成立，标志着西班牙区域统计演变史上的关键时刻。这一举措是西班牙全国范围内更广泛运动的一部分，旨在分散行政职能并加强区域治理。
    example_after = 加泰罗尼亚统计局成立于 1989 年，负责独立于西班牙国家统计局收集和发布区域统计数据。
  pattern2 =
    name = 过度强调知名度和媒体报道
    problem = LLM 反复强调知名度主张，通常列出来源而不提供上下文。
    example_before = 她的观点被《纽约时报》、BBC、《金融时报》和《印度教徒报》引用。她在社交媒体上拥有活跃的存在，拥有超过 50 万粉丝。
    example_after = 在 2024 年《纽约时报》的采访中，她认为 AI 监管应该关注结果而不是方法。
  pattern3 =
    name = 以 -ing 结尾的肤浅分析
    problem = AI 聊天机器人在句子末尾添加现在分词（"-ing"）短语来增加虚假深度。
    example_before = 寺庙的蓝色、绿色和金色色调与该地区的自然美景产生共鸣，象征着德克萨斯州的蓝帽花、墨西哥湾和多样化的德克萨斯州景观，反映了社区与土地的深厚联系。
    example_after = 寺庙使用蓝色、绿色和金色。建筑师表示这些颜色是为了呼应当地的蓝帽花和墨西哥湾海岸。
  pattern4 =
    name = 宣传和广告式语言
    problem = LLM 在保持中立语气方面存在严重问题，尤其是对于"文化遗产"话题。倾向使用夸张的宣传性语言。
    example_before = 坐落在埃塞俄比亚贡德尔地区令人叹为观止的区域内，Alamata Raya Kobo 是一座充满活力的城镇，拥有丰富的文化遗产和迷人的自然美景。
    example_after = Alamata Raya Kobo 是埃塞俄比亚贡德尔地区的一座城镇，以其每周集市和 18 世纪教堂而闻名。
  pattern5 =
    name = 模糊归因和含糊措辞
    problem = AI 聊天机器人将观点归因于模糊的权威而不提供具体来源。
    example_before = 由于其独特的特征，浩来河引起了研究人员和保护主义者的兴趣。专家认为它在区域生态系统中发挥着至关重要的作用。
    example_after = 根据中国科学院 2019 年的调查，浩来河支持多种特有鱼类。
  pattern6 =
    name = 提纲式的"挑战与未来展望"部分
    problem = 许多 LLM 生成的文章包含公式化的"挑战"部分。
    example_before = 尽管工业繁荣，Korattur 面临着城市地区典型的挑战，包括交通拥堵和水资源短缺。尽管存在这些挑战，凭借其战略位置和正在进行的举措，Korattur 继续蓬勃发展，成为钦奈增长不可或缺的一部分。
    example_after = 2015 年三个新 IT 园区开业后，交通拥堵加剧。市政公司于 2022 年启动了雨水排水项目，以解决反复发生的洪水。

language_patterns =
  pattern7 =
    name = 过度使用的"AI 词汇"
    problem = 这些词在 2023 年后的文本中出现频率要高得多。它们经常共同出现。
    example_before = 此外，索马里菜肴的一个显著特征是加入骆驼肉。意大利殖民影响的持久证明是当地烹饪格局中广泛采用意大利面，展示了这些菜肴如何融入传统饮食。
    example_after = 索马里菜肴还包括骆驼肉，被认为是一种美味。在意大利殖民期间引入的意大利面菜肴仍然很常见，尤其是在南部。
  pattern8 =
    name = 避免使用"是"（系动词回避）
    problem = LLM 用复杂的结构替代简单的系动词。
    example_before = Gallery 825 作为 LAAA 的当代艺术展览空间。画廊设有四个独立空间，拥有超过 3000 平方英尺。
    example_after = Gallery 825 是 LAAA 的当代艺术展览空间。画廊有四个房间，总面积 3000 平方英尺。
  pattern9 =
    name = 否定式排比
    problem = "不仅……而且……"或"这不仅仅是关于……，而是……"等结构被过度使用。
    example_before = 这不仅仅是节拍在人声下流动；它是攻击性和氛围的一部分。这不仅仅是一首歌，而是一种声明。
    example_after = 沉重的节拍增加了攻击性的基调。
  pattern10 =
    name = 三段式法则过度使用
    problem = LLM 强行将想法分成三组以显得全面。
    example_before = 活动包括主题演讲、小组讨论和社交机会。与会者可以期待创新、灵感和行业洞察。
    example_after = 活动包括演讲和小组讨论。会议之间还有非正式社交的时间。
  pattern11 =
    name = 刻意换词（同义词循环）
    problem = AI 有重复惩罚代码，导致过度使用同义词替换。
    example_before = 主人公面临许多挑战。主要角色必须克服障碍。中心人物最终获得胜利。英雄回到家中。
    example_after = 主人公面临许多挑战，但最终获得胜利并回到家中。
  pattern12 =
    name = 虚假范围
    problem = LLM 使用"从 X 到 Y"的结构，但 X 和 Y 并不在有意义的尺度上。
    example_before = 我们穿越宇宙的旅程将我们从大爆炸的奇点带到宏伟的宇宙网，从恒星的诞生和死亡到暗物质的神秘舞蹈。
    example_after = 这本书涵盖了大爆炸、恒星形成和当前关于暗物质的理论。

style_patterns =
  pattern13 =
    name = 破折号过度使用
    problem = LLM 使用破折号（—）比人类更频繁，模仿"有力"的销售文案。
    example_before = 这个术语主要由荷兰机构推广——而不是由人民自己。你不会说"荷兰，欧洲"作为地址——但这种错误标记仍在继续——即使在官方文件中。
    example_after = 这个术语主要由荷兰机构推广，而不是由人民自己。你不会说"荷兰，欧洲"作为地址，但这种错误标记在官方文件中仍在继续。
  pattern14 =
    name = 粗体过度使用
    problem = AI 聊天机器人机械地用粗体强调短语。
    example_before = 它融合了 **OKR（目标和关键结果）**、**KPI（关键绩效指标）** 和视觉战略工具，如 **商业模式画布（BMC）** 和 **平衡计分卡（BSC）**。
    example_after = 它融合了 OKR、KPI 和视觉战略工具，如商业模式画布和平衡计分卡。
  pattern15 =
    name = 内联标题垂直列表
    problem = AI 输出列表，其中项目以粗体标题开头，后跟冒号。
    example_before = - **用户体验：** 用户体验通过新界面得到显著改善。
      - **性能：** 性能通过优化算法得到增强。
      - **安全性：** 安全性通过端到端加密得到加强。
    example_after = 更新改进了界面，通过优化算法加快了加载时间，并添加了端到端加密。
  pattern16 =
    name = 标题中的标题大写
    problem = AI 聊天机器人将标题中的所有主要单词大写。
    note = 中文标题通常不涉及大小写问题，此模式在中文中不太适用。
  pattern17 =
    name = 表情符号
    problem = AI 聊天机器人经常用表情符号装饰标题或项目符号。
    example_before = 🚀 **启动阶段：** 产品在第三季度发布
      💡 **关键洞察：** 用户更喜欢简单
      ✅ **下一步：** 安排后续会议
    example_after = 产品在第三季度发布。用户研究显示更喜欢简单。下一步：安排后续会议。
  pattern18 =
    name = 弯引号
    problem = ChatGPT 使用弯引号（""）而不是直引号（""）。
    note = 中文通常使用中文引号（「」或""），此模式在中文中表现为英文引号的使用。

communication_patterns =
  pattern19 =
    name = 协作交流痕迹
    problem = 作为聊天机器人对话的文本被粘贴为内容。
    example_before = 这是法国大革命的概述。希望这对您有帮助！如果您想让我扩展任何部分，请告诉我。
    example_after = 法国大革命始于 1789 年，当时财政危机和粮食短缺导致了广泛的动荡。
  pattern20 =
    name = 知识截止日期免责声明
    problem = 关于信息不完整的 AI 免责声明留在文本中。
    example_before = 虽然关于公司成立的具体细节在现成资料中没有广泛记录，但它似乎是在 20 世纪 90 年代的某个时候成立的。
    example_after = 根据注册文件，该公司成立于 1994 年。
  pattern21 =
    name = 谄媚/卑躬屈膝的语气
    problem = 过于积极、讨好的语言。
    example_before = 好问题！您说得完全正确，这是一个复杂的话题。关于经济因素，这是一个很好的观点。
    example_after = 您提到的经济因素在这里是相关的。

filler_patterns =
  pattern22 =
    name = 填充短语
    examples =
      = "为了实现这一目标" → "为了实现这一点"
      = "由于下雨的事实" → "因为下雨"
      = "在这个时间点" → "现在"
      = "在您需要帮助的情况下" → "如果您需要帮助"
      = "系统具有处理的能力" → "系统可以处理"
      = "值得注意的是数据显示" → "数据显示"
  pattern23 =
    name = 过度限定
    problem = 过度限定陈述。
    example_before = 可以潜在地可能被认为该政策可能会对结果产生一些影响。
    example_after = 该政策可能会影响结果。
  pattern24 =
    name = 通用积极结论
    problem = 模糊的乐观结尾。
    example_before = 公司的未来看起来光明。激动人心的时代即将到来，他们继续追求卓越的旅程。这代表了向正确方向迈出的重要一步。
    example_after = 该公司计划明年再开设两个地点。

checklist =
  item1 = 连续三个句子长度相同？打断其中一个
  item2 = 段落以简洁的单行结尾？变换结尾方式
  item3 = 揭示前有破折号？删除它
  item4 = 解释隐喻或比喻？相信读者能理解
  item5 = 使用了"此外""然而"等连接词？考虑删除
  item6 = 三段式列举？改为两项或四项

workflow =
  step1 = 仔细阅读输入文本
  step2 = 识别上述所有模式的实例
  step3 = 重写每个有问题的部分
  step4 = 确保修订后的文本
    sub1 = 大声朗读时听起来自然
    sub2 = 自然地改变句子结构
    sub3 = 使用具体细节而不是模糊的主张
    sub4 = 为上下文保持适当的语气
    sub5 = 适当时使用简单的结构（是/有）
  step5 = 呈现人性化版本

output_format =
  item1 = 重写后的文本
  item2 = 所做更改的简要总结（如果有帮助，可选）

quality_scoring =
  total_points = 50
  dimensions =
    directness =
      criteria = 直接陈述事实还是绕圈宣告？10 分：直截了当；1 分：充满铺垫
      max_score = 10
    rhythm =
      criteria = 句子长度是否变化？10 分：长短交错；1 分：机械重复
      max_score = 10
    trust =
      criteria = 是否尊重读者智慧？10 分：简洁明了；1 分：过度解释
      max_score = 10
    authenticity =
      criteria = 听起来像真人说话吗？10 分：自然流畅；1 分：机械生硬
      max_score = 10
    conciseness =
      criteria = 还有可删减的内容吗？10 分：无冗余；1 分：大量废话
      max_score = 10
  standards =
    excellent = 45-50 分：优秀，已去除 AI 痕迹
    good = 35-44 分：良好，仍有改进空间
    needs_revision = 低于 35 分：需要重新修订

full_example =
  before = 新的软件更新作为公司致力于创新的证明。此外，它提供了无缝、直观和强大的用户体验——确保用户能够高效地完成目标。这不仅仅是一次更新，而是我们思考生产力方式的革命。行业专家认为这将对整个行业产生持久影响，彰显了公司在不断演变的技术格局中的关键作用。
  after = 软件更新添加了批处理、键盘快捷键和离线模式。来自测试用户的早期反馈是积极的，大多数报告任务完成速度更快。
  changes =
    = 删除了"作为……的证明"（夸大的象征意义）
    = 删除了"此外"（AI 词汇）
    = 删除了"无缝、直观和强大"（三段式法则 + 宣传性）
    = 删除了破折号和"-确保"短语（肤浅分析）
    = 删除了"这不仅仅是……而是……"（否定式排比）
    = 删除了"行业专家认为"（模糊归因）
    = 删除了"关键作用"和"不断演变的格局"（AI 词汇）
    = 添加了具体功能和具体反馈

reference =
  source = Wikipedia:Signs of AI writing
  url = https://en.wikipedia.org/wiki/Wikipedia:Signs_of_AI_writing
  maintainer = WikiProject AI Cleanup
  key_insight = LLM 使用统计算法来猜测接下来应该是什么。结果倾向于适用于最广泛情况的统计上最可能的结果。
